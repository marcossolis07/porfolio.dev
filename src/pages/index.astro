---
import Layout from '../layouts/Layout.astro';

import SectionContainer from '../components/SectionContainer.astro'
import Experience from '../components/Experience.astro';
import Briefcase from '../icons/Briefcase.astro';
import Code from '../icons/Code.astro';
import Settings from '../icons/Settings.astro';
import Skills from '../components/Skills.astro';
import ProfileCheck from '../icons/ProfileCheck.astro';
import AboutMe from '../components/AboutMe.astro'
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import ContactSection from '../components/ContactSection.astro';

const showExperience = true;
---

<Layout 
	title="Marcos Solis | Desarrollador web full stack freelance (Santa Fe)"
	description="Desarrollador full stack freelance: ecommerce, sitios a medida, paneles de administración y sistemas reutilizables. Santa Fe, Argentina. Contratá para productos web completos."
>
	<main class="px-4">
		<SectionContainer class="py-16 md:py-36">
			<Hero>
			</slot>
			</Hero>
		</SectionContainer>
		<div class="space-y-24">
		{showExperience && (
		<SectionContainer id="experiencia">
			<h2 class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-blue-600 dark:text-white">
				<Briefcase class="size-8"/>
				Experiencia Laboral
			</h2>

			<Experience />
		</SectionContainer>
		)}

		<SectionContainer id="proyectos">
			<h2 class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-blue-600 dark:text-white">
				<Code class="size-8"/>
				Proyectos
			</h2>

			<Projects />
		</SectionContainer>

		<SectionContainer id="habilidades">
			<h2 class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-blue-600 dark:text-white">
				<Settings class="size-8"/>
				Habilidades
			</h2>

			<Skills />
		</SectionContainer>

		<SectionContainer id="sobre-mi">
			<h2
			  class="flex items-center mb-6 text-3xl font-semibold gap-x-8 text-blue-600 dark:text-white"
			>
			  <ProfileCheck class="size-8" />
			  Sobre mí
			</h2>
			<AboutMe />
		  </SectionContainer>

		<SectionContainer id="contacto" class="pb-8">
			<ContactSection />
		</SectionContainer>
		</div>
	</main>
</Layout>