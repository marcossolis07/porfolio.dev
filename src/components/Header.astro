---
import ThemeToggle from "../components/ThemeToggle.astro";

const showExperience = true;
const navItems = [
  {
    title: "Experiencia",
    label: "experiencia",
    url: "#experiencia",
    hidden: !showExperience,
  },
  {
    title: "Proyectos",
    label: "proyectos",
    url: "#proyectos",
  },
  {
    title: "Habilidades",
    label: "habilidades",
    url: "#habilidades",
  },
  {
    title: "Sobre mí",
    label: "sobre-mi",
    url: "#sobre-mi",
  },
  {
    title: "Contacto",
    label: "contacto",
    url: "#contacto",
  },
];
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-6"
>
  <nav
    class="flex px-3 text-sm font-medium rounded-full text-gray-800 dark:text-gray-200 justify-center items-center"
  >
    {
      navItems.filter((link) => !link.hidden).map((link) => (
        <a
          class="relative block px-2 py-2 transition hover:text-blue-600 dark:hover:text-yellow-400"
          aria-label={link.label}
          href={link.url}
          data-nav-anchor={link.url.startsWith("#") ? "true" : undefined}
        >
          {link.title}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  html.dark nav {
    animation-name: nav-shadown-dark;
  }

  @keyframes nav-shadown {
    to {
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
      border-width: 1px;
      border-color: rgb(229 231 235);
      backdrop-filter: blur(20px);
      background-color: rgba(255, 255, 255, 0.9);
      border-radius: 9999px;
    }
  }

  @keyframes nav-shadown-dark {
    to {
      box-shadow: 0 5px 50px -5px rgba(0, 0, 0, 0.3);
      border-width: 1px;
      border-color: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
      background-color: rgba(31, 41, 55, 0.9);
      border-radius: 9999px;
    }
  }
</style>

<script is:inline>
  /** @param {string} hash */
  function scrollToSectionHash(hash) {
    const id = hash.startsWith("#") ? hash.slice(1) : hash;
    if (!id) return false;
    const el = document.getElementById(id);
    if (!el) return false;
    el.scrollIntoView({ behavior: "smooth", block: "start" });
    history.replaceState(null, "", "#" + id);
    return true;
  }

  document.addEventListener("click", (e) => {
    const t = e.target;
    if (!(t instanceof Element)) return;
    const a = t.closest("a[data-nav-anchor]");
    if (!a || !(a instanceof HTMLAnchorElement)) return;
    const href = a.getAttribute("href");
    if (!href || !href.startsWith("#")) return;
    if (!scrollToSectionHash(href)) return;
    e.preventDefault();
  });

  document.addEventListener("astro:page-load", () => {
    if (typeof window === "undefined" || !window.location.hash) return;
    requestAnimationFrame(function () {
      scrollToSectionHash(window.location.hash);
    });
  });
</script>

