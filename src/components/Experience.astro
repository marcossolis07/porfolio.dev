---
import ExperienceItems from "./ExperienceItems.astro";

const experiences = [
  {
    date: "Nov 2023 - Actualidad",
    title: "Desarrollador full stack — Autónomo / Freelance",
    company: "Proyectos con clientes y productos propios",
    description:
      "Diseño, desarrollo y despliegue de aplicaciones web a medida (ecommerce, sitios institucionales, sistemas con panel de administración y producto reutilizable para concesionarias), trabajo end-to-end en frontend y backend y coordinación con clientes.",
  },
];
---

<ol class="relative mt-16">
  {
    experiences?.map((experience) => (
      <li class="">
        <ExperienceItems {...experience} />
      </li>
    ))
  }
</ol>

