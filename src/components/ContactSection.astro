---
import MailIcon from "../icons/Mail.astro";
import Whatsapp from "../icons/Whatsapp.astro";

const email = "marcossolis023@gmail.com";
const whatsappHref =
  "https://api.whatsapp.com/send?phone=5493425928293&text=" +
  encodeURIComponent("Hola Marcos, te escribo por tu portfolio.");
---

<h2
  class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-blue-600 dark:text-white"
>
  <MailIcon class="size-8 shrink-0" />
  Comunicate conmigo
</h2>
<p class="mb-8 max-w-2xl text-gray-700 dark:text-gray-300 text-pretty">
  Escribime si querés encargar un proyecto web (sitio, ecommerce, sistema con panel de
  administración o algo a medida) o si representás a una empresa y buscás sumar un desarrollador
  al equipo: también evalúo propuestas en relación de dependencia, contrato o modalidad híbrida,
  no solo encargos puntuales de sitio. Elegí WhatsApp o mail abajo; leo todo y respondo en
  cuanto pueda.
</p>
<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap">
  <a
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center gap-2 px-5 py-3 text-base font-medium text-gray-900 transition bg-gray-100 border border-gray-300 rounded-xl dark:bg-gray-800 dark:border-gray-600 dark:text-white hover:bg-gray-900 hover:border-gray-700 hover:text-white dark:hover:bg-gray-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-yellow-500/80 dark:focus-visible:ring-offset-gray-900"
  >
    <Whatsapp class="size-5 shrink-0" />
    WhatsApp
  </a>
  <a
    href={`mailto:${email}`}
    class="inline-flex items-center justify-center gap-2 px-5 py-3 text-base font-medium text-gray-900 transition bg-gray-100 border border-gray-300 rounded-xl dark:bg-gray-800 dark:border-gray-600 dark:text-white hover:bg-gray-900 hover:border-gray-700 hover:text-white dark:hover:bg-gray-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-yellow-500/80 dark:focus-visible:ring-offset-gray-900"
  >
    <MailIcon class="size-5 shrink-0" />
    {email}
  </a>
</div>
